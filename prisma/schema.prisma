generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(cuid())
  clerkId        String        @unique
  fullName       String?
  email          String        @unique
  phone          String?
  country        String?       @default("Ghana")
  roleType       String?
  headline       String?
  experience     String?
  desiredRole    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  resumes        Resume[]
  fitAnalyses    FitAnalysis[]
  coverLetters   CoverLetter[]
  savedJobs      SavedJob[]
  applications   Application[]
  savedSearches  SavedSearch[]
  referrals      Referral[]
}

model Resume {
  id              String             @id @default(cuid())
  userId          String
  filename        String?
  originalName    String?
  fileUrl         String?
  parsedText      String?
  versionLabel    String?
  isPrimary       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences     ResumeExperience[]
  education       ResumeEducation[]
  skills          ResumeSkill[]
}

model ResumeExperience {
  id           String   @id @default(cuid())
  resumeId     String
  title        String
  company      String?
  startDate    DateTime?
  endDate      DateTime?
  description  String?
  achievements String?
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeEducation {
  id           String   @id @default(cuid())
  resumeId     String
  institution  String
  degree       String?
  fieldOfStudy String?
  startDate    DateTime?
  endDate      DateTime?
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeSkill {
  id              String   @id @default(cuid())
  resumeId        String
  skillName       String
  confidenceScore Float?
  source          String?
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Job {
  id              String        @id @default(cuid())
  externalSource  String?
  externalJobId   String?
  title           String
  companyName     String?
  location        String?
  country         String?
  workMode        String?
  seniorityLevel  String?
  employmentType  String?
  description     String?
  requirementsText String?
  applicationUrl  String?
  postedAt        DateTime?
  expiresAt       DateTime?
  status          String?
  fitAnalyses     FitAnalysis[]
  jobSkills       JobSkill[]
  applications    Application[]
  coverLetters    CoverLetter[]
}

model JobSkill {
  id            String   @id @default(cuid())
  jobId         String
  skillName     String
  requiredLevel String?
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model FitAnalysis {
  id               String       @id @default(cuid())
  userId           String
  jobId            String
  fitScore         Float
  verdict          String
  strengthsSummary String?
  gapsSummary      String?
  riskSummary      String?
  createdAt        DateTime     @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job              Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model CoverLetter {
  id           String   @id @default(cuid())
  userId       String
  jobId        String
  content      String
  versionLabel String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SavedJob {
  id           String   @id @default(cuid())
  userId       String
  externalJobId String  @unique @default(cuid())
  title        String
  companyName  String?
  location     String?
  country      String?
  workMode     String?
  applicationUrl String?
  savedAt      DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalJobId])
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  status    String
  appliedAt DateTime?
  notes     String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SavedSearch {
  id            String   @id @default(cuid())
  userId        String
  name          String
  searchQuery   String
  location      String?
  workMode      String?
  seniority     String?
  alertEnabled  Boolean  @default(true)
  alertFrequency String  @default("daily")
  lastNotified  DateTime?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  refereeEmail String
  referralCode String  @unique
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)
}

model WaitlistReferral {
  id          String   @id @default(cuid())
  referralCode String  @unique
  referralCount Int     @default(0)
  createdAt   DateTime @default(now())
}
