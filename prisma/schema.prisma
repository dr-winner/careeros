generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(cuid())
  clerkId        String        @unique
  fullName       String?
  email          String        @unique
  phone          String?
  country        String?       @default("Ghana")
  roleType       String?
  headline       String?
  experience     String?
  desiredRole    String?
  isPremium           Boolean    @default(false)
  premiumSince        DateTime?
  subscriptionStatus  String?    // "active" | "cancelled" | "expired" | "lifetime"
  billingCycle        String?    // "monthly" | "annual"
  currentPeriodEnd    DateTime?
  analysisCount       Int        @default(0)
  analysisResetAt     DateTime?  // when the monthly count resets
  bonusAnalyses       Int        @default(0)  // extra analyses earned via referrals
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  resumes        Resume[]
  fitAnalyses    FitAnalysis[]
  coverLetters   CoverLetter[]
  savedJobs      SavedJob[]
  applications   Application[]
  savedSearches  SavedSearch[]
  referrals         Referral[]
  interviewSessions InterviewSession[]
  interviewRooms    InterviewRoom[]

  @@index([clerkId])
  @@index([email])
}

model Resume {
  id              String             @id @default(cuid())
  userId          String
  filename        String?
  originalName    String?
  fileUrl         String?
  parsedText      String?
  versionLabel    String?
  isPrimary       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences     ResumeExperience[]
  education       ResumeEducation[]
  skills          ResumeSkill[]

  @@index([userId])
  @@index([userId, isPrimary])
}

model ResumeExperience {
  id           String   @id @default(cuid())
  resumeId     String
  title        String
  company      String?
  startDate    DateTime?
  endDate      DateTime?
  description  String?
  achievements String?
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeEducation {
  id           String   @id @default(cuid())
  resumeId     String
  institution  String
  degree       String?
  fieldOfStudy String?
  startDate    DateTime?
  endDate      DateTime?
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeSkill {
  id              String   @id @default(cuid())
  resumeId        String
  skillName       String
  confidenceScore Float?
  source          String?
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Job {
  id              String        @id @default(cuid())
  externalSource  String?
  externalJobId   String?
  title           String
  companyName     String?
  location        String?
  country         String?
  workMode        String?
  seniorityLevel  String?
  employmentType  String?
  description     String?
  requirementsText String?
  applicationUrl  String?
  postedAt        DateTime?
  expiresAt       DateTime?
  status          String?
  fitAnalyses     FitAnalysis[]
  jobSkills       JobSkill[]
  applications    Application[]
  coverLetters    CoverLetter[]

  @@index([title])
  @@index([companyName])
}

model JobSkill {
  id            String   @id @default(cuid())
  jobId         String
  skillName     String
  requiredLevel String?
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model FitAnalysis {
  id               String       @id @default(cuid())
  userId           String
  jobId            String
  fitScore         Float
  verdict          String
  strengthsSummary String?
  gapsSummary      String?
  riskSummary      String?
  createdAt        DateTime     @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job              Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, createdAt(sort: Desc)])
}

model CoverLetter {
  id           String   @id @default(cuid())
  userId       String
  jobId        String
  content      String
  versionLabel String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SavedJob {
  id             String   @id @default(cuid())
  userId         String
  externalJobId  String
  title          String
  companyName    String?
  location       String?
  country        String?
  workMode       String?
  applicationUrl String?
  savedAt        DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalJobId])
}

model Application {
  id           String              @id @default(cuid())
  userId       String
  jobId        String
  jobTitle     String?
  companyName  String?
  location     String?
  workMode     String?
  status       String
  appliedAt    DateTime?
  updatedAt    DateTime            @default(now()) @updatedAt
  notes        String?
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  job          Job?                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  history      ApplicationHistory[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, appliedAt(sort: Desc)])
}

model ApplicationHistory {
  id            String      @id @default(cuid())
  applicationId String
  previousStatus String?
  newStatus     String
  notes         String?
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([applicationId, createdAt(sort: Desc)])
}

model SavedSearch {
  id            String   @id @default(cuid())
  userId        String
  name          String
  searchQuery   String
  location      String?
  workMode      String?
  seniority     String?
  alertEnabled  Boolean  @default(true)
  alertFrequency String  @default("daily")
  lastNotified  DateTime?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, alertEnabled])
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  refereeEmail String
  referralCode String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@unique([referrerId, refereeEmail])
  @@index([referralCode])
}

model InterviewSession {
  id              String   @id @default(cuid())
  userId          String
  role            String
  experienceLevel String?
  messages        String
  score           Float?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

model InterviewRoom {
  id              String   @id @default(cuid())
  roomCode        String   @unique
  createdBy       String
  role            String
  experienceLevel String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([roomCode])
  @@index([createdBy])
}

model WaitlistReferral {
  id          String   @id @default(cuid())
  referralCode String  @unique
  referralCount Int     @default(0)
  createdAt   DateTime @default(now())
}
