# ===========================================
# CareerOS Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# ===========================================
# Authentication (Clerk)
# ===========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ===========================================
# Database (Neon PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DIRECT_URL=postgresql://user:password@host/database?sslmode=require

# ===========================================
# AI Providers (at least one required)
# ===========================================
GROQ_API_KEY=gsk_xxx
DEEPSEEK_API_KEY=sk-xxx
GEMINI_API_KEY=xxx
OPENAI_API_KEY=sk-xxx

# ===========================================
# Job Aggregators (for job search)
# ===========================================
ADZUNA_APP_ID=xxx
ADZUNA_APP_KEY=xxx
JOOBLE_API_KEY=xxx

# ===========================================
# Supabase Storage (for CV uploads)
# ===========================================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_KEY=xxx

# ===========================================
# Upstash Redis (for rate limiting & caching)
# ===========================================
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_ID=xxx
# Optional: override the "from" address (default: CareerOS <noreply@careeros.live>)
# EMAIL_FROM=CareerOS <noreply@yourdomain.com>

# ===========================================
# Analytics (PostHog)
# ===========================================
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===========================================
# Payments (Moolre — Mobile Money)
# ===========================================
MOOLRE_API_USER=xxx
MOOLRE_API_PUBKEY=xxx
# Private key — required for disbursements (referral rewards) and direct MoMo charges
MOOLRE_API_KEY=xxx
MOOLRE_ACCOUNT_NUMBER=xxx
MOOLRE_MONTHLY_AMOUNT=25
MOOLRE_ANNUAL_AMOUNT=199
# Set to "true" to use the Moolre sandbox for testing
MOOLRE_SANDBOX=false

# Moolre SMS (job alerts) — VAS key + approved Sender ID from app.moolre.com
MOOLRE_API_VASKEY=xxx
MOOLRE_SMS_SENDER_ID=CareerOS

# GHS paid to a referrer's MoMo when their referee goes Premium (default 5)
MOOLRE_REFERRAL_REWARD_GHS=5

# ===========================================
# Security
# ===========================================
# Random secret used to authenticate cron job requests from Vercel
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ===========================================
# Admin
# ===========================================
# Comma-separated list of emails that can access /admin
ADMIN_EMAILS=you@example.com

# ===========================================
# Optional: Custom Domain
# ===========================================
# NEXT_PUBLIC_APP_URL=https://your-domain.com
